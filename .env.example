# ============================================================
# PixelFlow 后端环境变量模板
# ============================================================
# 复制此文件为 backend/.env 并修改对应值:
#   cp .env.example backend/.env
# ============================================================

# === 数据库 (PostgreSQL) ===
DATABASE_URL=postgresql+asyncpg://pixelflow:CHANGE_ME@localhost:5432/pixelflow

# === Redis (Celery broker + result backend) ===
REDIS_URL=redis://localhost:6379/0

# === 对象存储 (MinIO) ===
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=pixelflow-media

# === FFmpeg (可选, 默认使用 PATH 中的命令) ===
# FFMPEG_BIN=ffmpeg
# FFPROBE_BIN=ffprobe
# Linux 示例:
# FFMPEG_BIN=/usr/bin/ffmpeg
# FFPROBE_BIN=/usr/bin/ffprobe

# === AI - DashScope (阿里云) ===
# 申请地址: https://dashscope.console.aliyun.com
DASHSCOPE_API_KEY=your-dashscope-api-key-here

# === 应用 ===
APP_ENV=production
DEBUG=false
# 生产环境务必更换为随机字符串 (可用: openssl rand -hex 32)
SECRET_KEY=CHANGE_ME_TO_RANDOM_STRING
# CORS 允许的前端域名, 逗号分隔
CORS_ORIGINS=http://localhost:3001,http://your-domain.com

# === 工作目录 ===
MEDIA_WORK_DIR=./media_work
